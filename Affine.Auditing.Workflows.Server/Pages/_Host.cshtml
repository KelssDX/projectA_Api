@page "/"
@namespace Affine.Auditing.Workflows.Server.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}

<div id="app">
    <div class="loading-container">
        <h3>Loading Elsa Studio...</h3>
        <div class="spinner"></div>
        <p>If this page doesn't load, try accessing the Elsa API directly at:</p>
        <a href="/elsa/api/workflow-definitions" target="_blank">https://localhost:5001/elsa/api/workflow-definitions</a>
    </div>
</div>

<style>
    .loading-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        max-width: 400px;
    }
    
    .spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #3498db;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 20px 0;
    }
    
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
    }
    
    #app {
        height: 100vh;
        width: 100vw;
    }
    
    a {
        color: #3498db;
        text-decoration: none;
    }
    
    a:hover {
        text-decoration: underline;
    }
</style>

<script>
    // Simple fallback message
    setTimeout(function() {
        document.querySelector('.loading-container').innerHTML = `
            <h3>Elsa Workflow Server is Running!</h3>
            <p>✅ Server: https://localhost:5001</p>
            <p>✅ Database: Connected to Risk_Workflow schema</p>
            <p>✅ API: <a href="/elsa/api/workflow-definitions" target="_blank">Workflow Definitions API</a></p>
            <p>✅ Management: <a href="/elsa/api/workflow-instances" target="_blank">Workflow Instances API</a></p>
            <hr style="margin: 20px 0;">
            <p><strong>Next Steps:</strong></p>
            <p>1. Use Postman or curl to test the API endpoints</p>
            <p>2. Create workflows via the API</p>
            <p>3. Or integrate with your existing application</p>
        `;
    }, 3000);
</script> 